#
# Part 5: Immediate ALU Functions
#
# This tests the immediate functions for the ALU
#

addi $1, $0, 10   # Final value: 10<A> (1010)
slli $2, $1, 2    # Final value: 40<28> (101000)
slti $3, $2, 10   # Final value: 0
sltiu $4, $2, 50  # Final value: 1
xori $5, $2, 28   # Final value: 52<34>(011100^101000 = 110100)
srli $6, $5, 2    # Final value: 13<D>
srai $7, $6, 2    # Final value: 3
ori $8, $2, 28    # Final value: 60<3C>(011100|101000 = 111100)
andi $9, $2, 28   # Final value: 8(011100&101000 = 001000)
add $10, $1, $0   # Final value: 10<A>
sub $11, $1, $2   # Final value: -30<FFE2>
sll $12, $1, $4   # Final value: 20<14> 
slt $13, $1, $2   # Final value: 1  
sltu $14, $11, $2 # Final value: 0  
addi $15, $0, 28  # Final value: 28<1C>
xor $16, $15, $2  # Final value: 52<34>   
srl $17, $16, $4  # Final value: 26<1A> 
sra $18, $11, $4  # Final value: -15<FFF1>
or $19, $2, $15   # Final value: 60<3C>
and $20, $2, $15  # Final value: 8
